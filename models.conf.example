# models.conf — map friendly aliases to provider and model strings.
# Copy to models.conf and adjust. install.sh does this automatically if models.conf is absent.
# Format:  <alias> = <codex|claude|gemini> <exact model string>
# Unmatched raw slugs require an inferable provider. Re-verify after CLI upgrades: dispatch doctor
#
# Real slugs (codex-cli 0.144.6, from ~/.codex/models_cache.json):
#   gpt-5.6-sol    frontier agentic coding (most capable)
#   gpt-5.6-terra  balanced, everyday work
#   gpt-5.6-luna   fast + affordable
#   gpt-5.5        frontier for complex coding/research
#   gpt-5.4        strong everyday
#   gpt-5.4-mini   small, fast, cheap

# Shorthands
5.6       = codex gpt-5.6-sol
5.5       = codex gpt-5.5
5.4       = codex gpt-5.4
mini      = codex gpt-5.4-mini
default   = codex gpt-5.6-terra

# Explicit 5.6 variants (override the bare "5.6" default when you want)
5.6-sol   = codex gpt-5.6-sol
5.6-terra = codex gpt-5.6-terra
5.6-luna  = codex gpt-5.6-luna

sonnet    = claude sonnet
opus      = claude opus
haiku     = claude haiku

# gemini stub (CLI not installed; flags UNVERIFIED — do not run):
# gpro    = gemini gemini-2.5-pro
