#!/usr/bin/env bash
# dispatch — a thin conversational foreman for spawning Codex workers per GitHub issue.
#
# The lead agent (Claude Code / Fable) parses your natural-language assignments and calls
# these subcommands. Each worker runs `codex exec` headless in its own git worktree/branch.
# State lives in <target-repo>/.dispatch/ so "who's on what" survives crashes and new sessions.
#
# Subcommands:
#   dispatch doctor                       Check deps, list real Codex model strings, validate aliases
#   dispatch models                       List model aliases -> real slugs + descriptions
#   dispatch usage [--json] [--probe|--live] Show provider subscription usage and reset windows
#   dispatch start <issue#> <model> [-R repo]   Spawn a worker on an issue
#   dispatch status [issue#]              Show all jobs (or one) with live state
#   dispatch logs <issue#> [-f]           Tail a worker's log
#   dispatch stop <issue#>                Kill a running worker (keeps the worktree)
#   dispatch pr <issue#>                  Push the branch and open a PR (lead reviews first)
#   dispatch clean <issue#>               Remove the worktree + branch + job state
#
# <model> may be an alias from models.conf (e.g. 5.6) or a raw Codex model string.
set -euo pipefail

VERSION="0.1.0"
# Resolve through symlinks so models.conf is found when invoked via ~/.local/bin/dispatch.
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"; [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
SELF_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
MODELS_CONF="${DISPATCH_MODELS_CONF:-$SELF_DIR/../models.conf}"

die() { echo "dispatch: $*" >&2; exit 1; }
now() { date -u +%FT%TZ; }

need() { command -v "$1" >/dev/null 2>&1 || die "'$1' not found on PATH${2:+ — $2}"; }

repo_root() {
  git -C "${1:-.}" rev-parse --show-toplevel 2>/dev/null \
    || die "not inside a git repo. Run from the target repo (the one with the issues), or pass -R <path>."
}

# Print "provider model" for an alias, or infer the provider from a raw model slug.
resolve_model() {
  local key="$1" val="" provider model
  if [[ -f "$MODELS_CONF" ]]; then
    val="$(awk -F= -v key="$key" '
      /^[[:space:]]*#/ { next }
      NF >= 2 { alias=$1; gsub(/^[[:space:]]+|[[:space:]]+$/, "", alias)
        if (alias == key) { sub(/^[^=]*=[[:space:]]*/, ""); sub(/[[:space:]]*$/, ""); print; exit } }
      ' "$MODELS_CONF")"
  fi
  if [[ -n "$val" ]]; then
    provider="${val%%[[:space:]]*}"
    model="${val#"$provider"}"; model="${model#${model%%[![:space:]]*}}"
    [[ "$provider" =~ ^(codex|claude|gemini)$ && -n "$model" ]] \
      || die "invalid model alias '$key': expected '<provider> <model>' in $MODELS_CONF"
    printf '%s %s\n' "$provider" "$model"
    return
  fi
  case "$key" in
    gpt-*|codex-*) provider="codex" ;;
    claude-*) provider="claude" ;;
    gemini-*) provider="gemini" ;;
    *) die "model alias '$key' not found and provider cannot be inferred; add it to $MODELS_CONF as '<alias> = <provider> <model>'" ;;
  esac
  printf '%s %s\n' "$provider" "$key"
}

meta_get() { # meta_get <jobdir> <key>
  grep -E "^$2=" "$1/meta" 2>/dev/null | head -1 | sed "s/^$2=//"
}

# RUNNING | DONE | FAILED(code) | KILLED
job_state() {
  local jd="$1" pid ec
  if [[ -f "$jd/exitcode" ]]; then
    ec="$(cat "$jd/exitcode")"
    [[ "$ec" == "0" ]] && echo "DONE" || echo "FAILED($ec)"
    return
  fi
  pid="$(cat "$jd/pid" 2>/dev/null || true)"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then echo "RUNNING"; else echo "KILLED"; fi
}

# Human summary of the latest codex --json event. Schema (see docs/codex-events.md):
#   thread.started | turn.started | item.started | item.completed | turn.completed
#   item.type ∈ { agent_message(.text) | file_change(.changes[]) | command_execution(.command,.exit_code) }
last_event() {
  local jd="$1" f="$1/events.jsonl" provider line
  provider="$(meta_get "$jd" provider)"; provider="${provider:-codex}"
  line="$(grep -E '^\s*\{' "$f" 2>/dev/null | tail -1)"
  [[ -z "$line" ]] && line="$(tail -1 "$f" 2>/dev/null || true)"
  [[ -z "$line" ]] && return
  if command -v jq >/dev/null 2>&1 && printf '%s\n' "$line" | jq -e . >/dev/null 2>&1; then
    if [[ "$provider" == "codex" ]]; then
      printf '%s\n' "$line" | jq -r '
      if (.type | test("^item")) then
        (.item.type) as $it |
        if   $it=="agent_message"     then "msg: "  + (((.item.text//"")|gsub("\\s+";" "))[0:120])
        elif $it=="command_execution" then "run: "  + (((.item.command//"")|gsub("\\s+";" "))[0:90]) + (if .item.exit_code!=null then " (exit \(.item.exit_code))" else " …" end)
        elif $it=="file_change"       then "edit: " + ([.item.changes[]? | "\(.kind) \(.path|split("/")|last)"] | join(", "))
        else (.type + " " + ($it // "")) end
      elif .type=="turn.completed" then "turn done (\(.usage.output_tokens // "?") out tok)"
      elif .type=="thread.started" then "started"
      else .type end' 2>/dev/null || echo "${line:0:140}"
    elif [[ "$provider" == "claude" ]]; then
      printf '%s\n' "$line" | jq -r '
        if .type=="assistant" then
          ([.message.content[]? | if .type=="text" then "msg: " + ((.text//""|gsub("\\s+";" "))[0:120]) elif .type=="tool_use" then "tool: " + (.name//"unknown") else empty end] | join(", "))
        elif .type=="result" then "result: " + ((.result//.text//""|gsub("\\s+";" "))[0:120])
        elif .type=="system" then "started" else .type end' 2>/dev/null || echo "${line:0:140}"
    else
      echo "${line:0:140}"
    fi
  else
    echo "${line:0:140}"
  fi
}

cmd_doctor() {
  local ok=1
  echo "dispatch $VERSION — doctor"
  echo
  for t in git gh jq; do
    if command -v "$t" >/dev/null 2>&1; then echo "  ok   $t ($($t --version 2>/dev/null | head -1))"; else echo "  MISS $t"; ok=0; fi
  done
  echo
  echo "Providers:"
  local provider path version
  for provider in codex claude gemini; do
    if path="$(command -v "$provider" 2>/dev/null)"; then
      version="$($provider --version 2>/dev/null | head -1)"
      echo "  installed  $provider  $path${version:+ ($version)}"
    else
      echo "  MISSING    $provider"
    fi
  done
  echo
  echo "Codex model strings (source of truth for models.conf):"
  if command -v codex >/dev/null 2>&1; then
    # These vary by version; try the documented surfaces and show whatever exists.
    codex exec --help 2>/dev/null | grep -iA2 -- '-m,\|--model' | sed 's/^/    /' || true
    echo "    (also try:  codex --help  |  codex models  — fill real strings into $MODELS_CONF)"
  else
    echo "    (install codex first, then re-run 'dispatch doctor')"
  fi
  echo
  echo "models.conf aliases  ($MODELS_CONF):"
  if [[ -f "$MODELS_CONF" ]]; then
    grep -E '^[[:space:]]*[^#].*=' "$MODELS_CONF" | while IFS= read -r l; do echo "    $l"; done
  else
    echo "    MISSING — copy models.conf.example -> models.conf"; ok=0
  fi
  echo
  [[ "$ok" == 1 ]] && echo "Ready." || echo "Not ready — resolve the MISS/MISSING items above."
  [[ "$ok" == 1 ]]
}

cmd_start() {
  local n="" alias="" repo="."
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo) repo="$2"; shift 2 ;;
      *) if [[ -z "$n" ]]; then n="$1"; elif [[ -z "$alias" ]]; then alias="$1"; fi; shift ;;
    esac
  done
  [[ -n "$n" && -n "$alias" ]] || die "usage: dispatch start <issue#> <model> [-R repo]"
  [[ "$n" =~ ^[0-9]+$ ]] || die "issue# must be a number, got '$n'"
  need gh; need git; need jq

  local root sd jd provider model resolved branch wt issue_json title body gitcommon
  root="$(repo_root "$repo")"
  sd="$root/.dispatch"; jd="$sd/jobs/$n"
  [[ -e "$jd" ]] && die "job for issue #$n already exists. (dispatch status $n | dispatch stop $n | dispatch clean $n)"

  resolved="$(resolve_model "$alias")"
  read -r provider model <<< "$resolved"
  command -v "$provider" >/dev/null 2>&1 || die "$provider not installed"
  branch="dispatch/issue-$n"
  wt="$(cd "$root/.." && pwd)/$(basename "$root")-wt-issue-$n"

  issue_json="$(cd "$root" && gh issue view "$n" --json number,title,body 2>/dev/null)" \
    || die "could not fetch issue #$n via gh (wrong repo, or not authed?)"
  title="$(echo "$issue_json" | jq -r '.title')"
  body="$(echo "$issue_json" | jq -r '.body // ""')"

  mkdir -p "$jd"

  cat > "$jd/prompt.txt" <<EOF
You are an autonomous coding worker. Implement GitHub issue #$n on the current git branch ($branch).

TITLE: $title

DESCRIPTION:
$body

RULES:
- Work only on the current branch ($branch). Never switch or create branches.
- Keep the change minimal and scoped strictly to this issue. No "while I'm here" edits.
- If the repo has tests or a build, run them and make sure they pass before finishing.
- Commit your work with a clear message that references #$n. Do NOT push and do NOT open a PR — the lead reviews and merges.
- If the issue is ambiguous or you get blocked, stop and explain the blocker in your final message rather than guessing.
EOF

  git -C "$root" worktree add -b "$branch" "$wt" >/dev/null 2>&1 \
    || die "worktree add failed (branch '$branch' may already exist; try: dispatch clean $n)"

  # A worktree's git metadata lives under the MAIN repo's .git (the common dir), OUTSIDE the
  # worktree. codex --sandbox workspace-write can't write there, so `git commit` fails with
  # "Operation not permitted" on index.lock. Make the common .git writable via --add-dir.
  gitcommon="$(git -C "$wt" rev-parse --path-format=absolute --git-common-dir)"

  # Per-job runner avoids nested-quote hell and captures the exit code.
  # -C targets the worktree; -o writes the worker's final message for clean status reporting.
  case "$provider" in
  codex) cat > "$jd/run.sh" <<EOF
#!/usr/bin/env bash
# Keep stdout (--json JSONL events) and stderr (human progress) in separate files so a TUI/
# status can parse clean events while 'dispatch logs' shows readable progress.
codex exec -C "$wt" -m "$model" --sandbox workspace-write --add-dir "$gitcommon" --json \\
  -o "$jd/last_message.txt" "\$(cat "$jd/prompt.txt")" \\
  > "$jd/events.jsonl" 2> "$jd/worker.log"
echo \$? > "$jd/exitcode"
EOF
    ;;
  claude) cat > "$jd/run.sh" <<EOF
#!/usr/bin/env bash
# This throwaway worktree is reviewed before merge, matching Codex workspace-write's trust model.
( cd "$wt" && claude -p "\$(cat "$jd/prompt.txt")" --model "$model" \\
    --output-format stream-json --verbose --add-dir "$gitcommon" --dangerously-skip-permissions ) \\
  > "$jd/events.jsonl" 2> "$jd/worker.log"
worker_ec=\$?
jq -r 'select(.type=="result") | .result // .text // empty' "$jd/events.jsonl" | tail -1 > "$jd/last_message.txt"
echo \$worker_ec > "$jd/exitcode"
EOF
    ;;
  gemini) cat > "$jd/run.sh" <<EOF
#!/usr/bin/env bash
# UNVERIFIED: Gemini CLI was unavailable during development; command flags and events may differ.
( cd "$wt" && gemini -p "\$(cat "$jd/prompt.txt")" --model "$model" --output-format stream-json ) \\
  > "$jd/events.jsonl" 2> "$jd/worker.log"
worker_ec=\$?
tail -1 "$jd/events.jsonl" > "$jd/last_message.txt"
echo \$worker_ec > "$jd/exitcode"
EOF
    ;;
  esac
  chmod +x "$jd/run.sh"

  cat > "$jd/meta" <<EOF
issue=$n
alias=$alias
provider=$provider
model=$model
branch=$branch
worktree=$wt
started_at=$(now)
EOF

  # run.sh owns worker.log (stderr) and events.jsonl (stdout); wrapper noise is discarded.
  nohup bash "$jd/run.sh" >/dev/null 2>&1 &
  echo $! > "$jd/pid"
  echo "$(now) start issue=$n alias=$alias provider=$provider model=$model pid=$(cat "$jd/pid")" >> "$sd/ledger.log"

  echo "started #$n  ->  provider=$provider model=$model (alias $alias)  branch=$branch  pid=$(cat "$jd/pid")"
  echo "worktree: $wt"
  echo "watch:    dispatch status $n   |   dispatch logs $n -f"
}

print_job_row() { # print_job_row <jobdir>
  local jd="$1" n st
  n="$(basename "$jd")"
  st="$(job_state "$jd")"
  printf "  #%-5s %-11s %-22s %s\n" "$n" "$st" "$(meta_get "$jd" model)" "$(meta_get "$jd" branch)"
  local ev
  if [[ "$st" != "RUNNING" && -s "$jd/last_message.txt" ]]; then
    ev="final: $(tr '\n' ' ' < "$jd/last_message.txt" | cut -c1-160)"
  else
    ev="$(last_event "$jd")"
  fi
  [[ -n "$ev" ]] && printf "         └─ %s\n" "$ev"
}

cmd_status() {
  local n="${1:-}" repo="." root sd
  [[ "$n" == "-R" ]] && { repo="$2"; n=""; }
  root="$(repo_root "$repo")"; sd="$root/.dispatch"
  [[ -d "$sd/jobs" ]] || { echo "no dispatched jobs in $(basename "$root")."; return; }
  if [[ -n "$n" ]]; then
    [[ -d "$sd/jobs/$n" ]] || die "no job for issue #$n"
    print_job_row "$sd/jobs/$n"
    echo "  worktree: $(meta_get "$sd/jobs/$n" worktree)"
    return
  fi
  echo "dispatched jobs in $(basename "$root"):"
  local found=0
  for jd in "$sd"/jobs/*/; do
    [[ -d "$jd" ]] || continue; found=1
    print_job_row "$jd"
  done
  [[ "$found" == 1 ]] || echo "  (none)"
}

cmd_logs() {
  local n="${1:-}"; shift || true
  [[ -n "$n" ]] || die "usage: dispatch logs <issue#> [-f]"
  local root; root="$(repo_root .)"
  local log="$root/.dispatch/jobs/$n/worker.log"
  [[ -f "$log" ]] || die "no log for issue #$n"
  if [[ "${1:-}" == "-f" ]]; then tail -f "$log"; else tail -40 "$log"; fi
}

cmd_stop() {
  local n="${1:-}"; [[ -n "$n" ]] || die "usage: dispatch stop <issue#>"
  local root jd pid; root="$(repo_root .)"; jd="$root/.dispatch/jobs/$n"
  [[ -d "$jd" ]] || die "no job for issue #$n"
  pid="$(cat "$jd/pid" 2>/dev/null || true)"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true; sleep 1; kill -9 "$pid" 2>/dev/null || true
    echo "killed" > "$jd/exitcode"
    echo "$(now) stop issue=$n pid=$pid" >> "$root/.dispatch/ledger.log"
    echo "stopped #$n (worktree kept: $(meta_get "$jd" worktree)). Reassign with: dispatch clean $n && dispatch start $n <model>"
  else
    echo "#$n is not running (state: $(job_state "$jd"))."
  fi
}

cmd_pr() {
  local n="${1:-}"; [[ -n "$n" ]] || die "usage: dispatch pr <issue#>"
  local root jd wt branch; root="$(repo_root .)"; jd="$root/.dispatch/jobs/$n"
  [[ -d "$jd" ]] || die "no job for issue #$n"
  wt="$(meta_get "$jd" worktree)"; branch="$(meta_get "$jd" branch)"
  # Gate only on tracked changes — untracked build artifacts (__pycache__, node_modules, dist)
  # are byproducts, not "unfinished work", and must not block the PR.
  if ! git -C "$wt" diff --quiet || ! git -C "$wt" diff --cached --quiet; then
    die "worktree has uncommitted changes to tracked files — worker didn't finish cleanly. Inspect: $wt"
  fi
  git -C "$wt" rev-parse --verify "$branch" >/dev/null 2>&1 || die "branch $branch missing"
  ( cd "$wt" && git push -u origin "$branch" && gh pr create --fill --head "$branch" --body "Closes #$n

Dispatched worker (model $(meta_get "$jd" model)). Reviewed by lead before open." )
  echo "$(now) pr issue=$n branch=$branch" >> "$root/.dispatch/ledger.log"
}

cmd_clean() {
  local n="${1:-}"; [[ -n "$n" ]] || die "usage: dispatch clean <issue#>"
  local root jd wt branch; root="$(repo_root .)"; jd="$root/.dispatch/jobs/$n"
  [[ -d "$jd" ]] || die "no job for issue #$n"
  wt="$(meta_get "$jd" worktree)"; branch="$(meta_get "$jd" branch)"
  local pid; pid="$(cat "$jd/pid" 2>/dev/null || true)"
  [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
  [[ -n "$wt" && -d "$wt" ]] && git -C "$root" worktree remove --force "$wt" 2>/dev/null || true
  [[ -n "$branch" ]] && git -C "$root" branch -D "$branch" 2>/dev/null || true
  rm -rf "$jd"
  echo "cleaned #$n (worktree, branch, and job state removed)."
}

# List model aliases with provider, resolved slug, and (for Codex) cached description.
# The /dispatch picker builds its menu from this, so options never drift from models.conf.
cmd_models() {
  [[ -f "$MODELS_CONF" ]] || die "no models.conf at $MODELS_CONF (copy models.conf.example)"
  local cache="$HOME/.codex/models_cache.json" alias provider value slug desc
  printf "%-10s %-10s %-22s %s\n" "ALIAS" "PROVIDER" "MODEL" "DESCRIPTION"
  grep -E '^[[:space:]]*[^#].*=' "$MODELS_CONF" | while IFS= read -r line; do
    alias="$(printf '%s' "$line" | sed 's/=.*//; s/[[:space:]]//g')"
    value="$(printf '%s' "$line" | sed 's/^[^=]*=//; s/^[[:space:]]*//; s/[[:space:]]*$//')"
    provider="${value%%[[:space:]]*}"
    slug="${value#"$provider"}"; slug="${slug#${slug%%[![:space:]]*}}"
    desc=""
    if [[ "$provider" == "codex" && -f "$cache" ]] && command -v jq >/dev/null 2>&1; then
      desc="$(jq -r --arg s "$slug" '.models[]? | select(.slug==$s) | .description // ""' "$cache" 2>/dev/null | head -1)"
    fi
    printf "%-10s %-10s %-22s %s\n" "$alias" "$provider" "$slug" "$desc"
  done
}

# First configured model for a provider. Usage limits are subscription-wide, not per alias/model;
# the model is included only to make the provider row recognizable.
usage_model() {
  local wanted="$1" value provider slug
  [[ -f "$MODELS_CONF" ]] || return
  while IFS= read -r line; do
    value="$(printf '%s' "$line" | sed 's/^[^=]*=//; s/^[[:space:]]*//; s/[[:space:]]*$//')"
    provider="${value%%[[:space:]]*}"
    [[ "$provider" == "$wanted" ]] || continue
    slug="${value#"$provider"}"; slug="${slug#${slug%%[![:space:]]*}}"
    printf '%s\n' "$slug"
    return
  done < <(grep -E '^[[:space:]]*[^#].*=' "$MODELS_CONF")
}

human_duration() {
  local seconds="$1" days hours mins
  (( seconds < 0 )) && seconds=0
  days=$((seconds / 86400)); hours=$(((seconds % 86400) / 3600)); mins=$(((seconds % 3600) / 60))
  if (( days > 0 )); then printf '%dd %dh' "$days" "$hours"
  elif (( hours > 0 )); then printf '%dh %dm' "$hours" "$mins"
  else printf '%dm' "$mins"
  fi
}

# Emit normalized JSON records. Codex writes the latest server-provided rate-limit snapshot into
# session JSONL token_count events. Claude exposes reset/status data through an opt-in live probe.
usage_records() {
  local probe="${1:-0}" provider model sessions latest snapshot window output event
  for provider in codex claude gemini; do
    model="$(usage_model "$provider")"
    [[ -n "$model" ]] || continue
    if [[ "$provider" == "codex" && -n "$(command -v jq 2>/dev/null)" ]]; then
      sessions="${DISPATCH_CODEX_SESSIONS_DIR:-$HOME/.codex/sessions}"
      latest="$(find "$sessions" -type f -name '*.jsonl' -print 2>/dev/null | while IFS= read -r f; do
        printf '%s\t%s\n' "$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)" "$f"
      done | sort -rn | head -1 | cut -f2-)"
      snapshot=""
      [[ -n "$latest" ]] && snapshot="$(jq -c 'select(.type=="event_msg" and .payload.type=="token_count" and .payload.rate_limits) | .payload.rate_limits' "$latest" 2>/dev/null | tail -1)"
      if [[ -n "$snapshot" ]]; then
        for window in primary secondary; do
          printf '%s\n' "$snapshot" | jq -c --arg p "$provider" --arg m "$model" --arg w "$window" '
            .[$w] | select(. != null and .used_percent != null) |
            {provider:$p, model:$m, window:$w, used_percent:.used_percent,
             window_minutes:.window_minutes, resets_at:.resets_at, available:true}'
        done
        continue
      fi
    fi
    if [[ "$provider" == "claude" && "$probe" == "1" && -n "$(command -v claude 2>/dev/null)" ]]; then
      output=""
      if output="$(claude -p "ok" --output-format stream-json --verbose < /dev/null 2>/dev/null)"; then
        event="$(printf '%s\n' "$output" | jq -c '
          (.rate_limit_event.rate_limit_info //
           (if .type == "rate_limit_event" then .rate_limit_info else empty end)) |
          select(. != null and .rateLimitType == "five_hour" and .resetsAt != null) |
          {status:(.status // null), resetsAt:.resetsAt}' 2>/dev/null | tail -1)"
        if [[ -n "$event" ]]; then
          printf '%s\n' "$event" | jq -c --arg p "$provider" --arg m "$model" '
            def epoch:
              if type == "number" then .
              else (try (sub("\\.[0-9]+Z$"; "Z") | fromdateiso8601) catch null)
              end;
            {provider:$p, model:$m, window:"5h", used_percent:null,
             window_minutes:300, resets_at:(.resetsAt | epoch), status:.status,
             available:true}'
          continue
        fi
      fi
    fi
    jq -nc --arg p "$provider" --arg m "$model" \
      '{provider:$p, model:$m, window:null, used_percent:null, window_minutes:null, resets_at:null, status:null, available:false}'
  done
}

cmd_usage() {
  local json=0 probe=0 records provider model window percent reset status now_epoch filled empty bar label
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1 ;;
      --probe|--live) probe=1 ;;
      *) die "usage: dispatch usage [--json] [--probe|--live]" ;;
    esac
    shift
  done
  need jq
  records="$(usage_records "$probe")"
  if [[ "$json" == 1 ]]; then
    printf '%s\n' "$records" | jq -s .
    return
  fi
  now_epoch="$(date +%s)"
  while IFS=$'\t' read -r provider model window percent reset status; do
    if [[ "$percent" == "n/a" ]]; then
      if [[ "$reset" != "n/a" ]]; then
        printf "%-7s %-18s [%-20s]  n/a   %-9s resets %s\n" "$provider" "$model" "" "${status:-$window}" "$(human_duration "$((reset - now_epoch))")"
      else
        printf "%-7s %-18s [%-20s]  n/a   resets n/a\n" "$provider" "$model" ""
      fi
      continue
    fi
    # Round to the nearest bar cell while preserving the server's percentage in the label.
    filled="$(awk -v p="$percent" 'BEGIN { n=int((p*20/100)+0.5); if(n<0)n=0; if(n>20)n=20; print n }')"
    empty=$((20 - filled)); bar=""
    while (( filled-- > 0 )); do bar+="█"; done
    while (( empty-- > 0 )); do bar+="░"; done
    label="$window"
    printf "%-7s %-18s [%s] %5s%%  %-9s resets %s\n" "$provider" "$model" "$bar" "$percent" "$label" "$(human_duration "$((reset - now_epoch))")"
  done < <(printf '%s\n' "$records" | jq -r '[.provider,.model,
    (if .available then (.window // (if .window_minutes==300 then "5h" elif .window_minutes==10080 then "weekly" else ((.window_minutes|tostring)+"m") end)) else "n/a" end),
    (if .used_percent != null then (.used_percent|tostring) else "n/a" end),
    (if .resets_at != null then (.resets_at|tostring) else "n/a" end),
    (.status // "")] | @tsv')
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    doctor) cmd_doctor "$@" ;;
    models) cmd_models "$@" ;;
    usage)  cmd_usage "$@" ;;
    start)  cmd_start "$@" ;;
    status) cmd_status "$@" ;;
    logs)   cmd_logs "$@" ;;
    stop)   cmd_stop "$@" ;;
    pr)     cmd_pr "$@" ;;
    clean)  cmd_clean "$@" ;;
    version|--version|-v) echo "dispatch $VERSION" ;;
    ""|help|-h|--help)
      sed -n '2,20p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown command '$cmd' (try: dispatch help)" ;;
  esac
}
main "$@"
